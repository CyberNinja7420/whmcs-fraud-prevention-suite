# Logs
logs/*.log
logs/*.txt
!logs/.gitkeep

# Runtime cache
cache/*
!cache/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Dependencies (none currently, but future-proof)
vendor/
node_modules/

# Environment (secrets should never be committed)
.env
.env.local

# Test artifacts
tests/output/
coverage/

# Compiled templates
templates_c/

# Internal files (not for public repo)
docs/demo/
docs/promotion/
.gitlab-ci.yml

# Large data files
data/sdn.csv

# Composer vendor at root is ignored, but in-module asset vendor copies are not
!assets/vendor/
!assets/vendor/**

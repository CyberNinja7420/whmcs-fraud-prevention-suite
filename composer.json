{
    "name": "evdps/fraud-prevention-suite",
    "description": "Enterprise-grade fraud detection addon for WHMCS with 16+ detection engines, REST API, and global threat intelligence.",
    "type": "whmcs-addon",
    "license": "MIT",
    "homepage": "https://github.com/CyberNinja7420/whmcs-fraud-prevention-suite",
    "support": {
        "issues": "https://github.com/CyberNinja7420/whmcs-fraud-prevention-suite/issues",
        "source": "https://github.com/CyberNinja7420/whmcs-fraud-prevention-suite"
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12"
    },
    "scripts": {
        "lint": "find . -name '*.php' -not -path './vendor/*' -not -path './phpstan-stubs/*' -not -path './docs/*' -print0 | xargs -0 -n1 -P4 php -l > /dev/null",
        "phpstan": "phpstan analyse --configuration=phpstan.neon.dist --no-progress --memory-limit=512M",
        "qa": [
            "@lint",
            "@phpstan"
        ]
    }
}
